{
  "name": "@hemanath-afk/afk-motion",
  "version": "2.0.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Premium React micro-interaction library for modern portfolios",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && node -e \"require('fs').copyFileSync('src/index.d.ts', 'dist/index.d.ts')\"",
    "preview": "vite preview"
  },
  "keywords": [
    "react",
    "framer-motion",
    "animation",
    "tilt",
    "magnetic-button",
    "micro-interaction",
    "parallax",
    "portfolio"
  ],
  "author": "Hemanath AFK",
  "license": "MIT",
  "peerDependencies": {
    "framer-motion": ">=11.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@vitejs/plugin-react": "^4.3.4",
    "framer-motion": "^11.18.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "semantic-release": "^25.0.3",
    "vite": "^6.0.7"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "lucide-react": "^1.17.0",
    "postcss": "^8.5.15",
    "react-router-dom": "^7.17.0",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.14"
  }
}
